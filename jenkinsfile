pipeline {
    agent any
    
    environment {
        SONAR_HOST_URL = 'http://localhost:9000'
        SONAR_PROJECT_KEY = 'meditracker'
        SONAR_TOKEN = credentials('sonar-token')
        DOCKER_IMAGE = "meditracker:${BUILD_NUMBER}"
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '📦 Récupération du code...'
                git branch: 'master', 
                    url: 'https://github.com/Yahya-maani/meditracker.git'
                   
            }
        }
        
        stage('Setup Python') {
            steps {
                echo '🐍 Configuration de Python...'
                withPythonEnv('C:\\Users\\PC\\AppData\\Local\\Programs\\Python\\Python310\\python.exe') {
                    bat '''
                        echo "=== Installation des dépendances ==="
                        python --version
                        pip install --upgrade pip
                        
                        REM Utilisation du fichier minimaliste
                        pip install -r requirements-minimal.txt
                        
                        REM Installation des outils de test
                        pip install pytest pytest-cov flake8
                        
                        echo "=== Vérification ==="
                        python -c "import flask; print('Flask OK')"
                        python -c "import pymongo; print('PyMongo OK')"
                    '''
                }
            }
        }
        
        stage('Run Tests') {
            steps {
                echo '🧪 Exécution des tests...'
                withPythonEnv('C:\\Users\\PC\\AppData\\Local\\Programs\\Python\\Python310\\python.exe') {
                    bat '''
                        echo "=== Lancement des tests ==="
                        if exist test_basic.py (
                            pytest test_basic.py -v
                        ) else (
                            echo "Test simple : Application chargée"
                            python -c "from app import app; print('Application OK')"
                        )
                    '''
                }
            }
        }
        
        stage('SonarQube Analysis') {
    steps {
        echo '🔍 Analyse SonarQube...'
        script {
            docker.image('sonarsource/sonar-scanner-cli:latest').inside(
                "-v \"C:\\ProgramData\\Jenkins\\.jenkins\\workspace\\medtracker:C:\\workspace\" -w C:\\workspace"
            ) {
                bat '''
                    sonar-scanner.bat ^
                        -Dsonar.projectKey=meditracker ^
                        -Dsonar.sources=. ^
                        -Dsonar.host.url=http://host.docker.internal:9000 ^
                        -Dsonar.login=%SONAR_TOKEN% ^
                        -Dsonar.python.version=3 ^
                        -Dsonar.sourceEncoding=UTF-8 ^
                        -Dsonar.exclusions=**/venv/**
                '''
            }
        }
    }
}
        
        stage('Quality Gate') {
            steps {
                echo '✅ Vérification Quality Gate...'
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }
    
    post {
        always {
            echo '🧹 Nettoyage terminé'
        }
        success {
            echo '✅ Pipeline réussi !'
        }
        failure {
            echo '❌ Pipeline échoué'
        }
    }
}