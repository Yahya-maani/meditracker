pipeline {
    agent any
    
    environment {
        SONAR_HOST_URL = 'http://localhost:9000'
        SONAR_PROJECT_KEY = 'meditracker'
        SONAR_TOKEN = credentials('sonar-token')
        DOCKER_IMAGE = "meditracker:${BUILD_NUMBER}"
        DOCKER_REGISTRY = 'docker.io/yahyamaani' 
        K8S_NAMESPACE = 'meditracker'
        DEPLOYMENT_NAME = 'meditracker-app'
        CONTAINER_PORT = '5000'
        
        // Monitoring metrics
        DEPLOYMENT_STATUS = 'success'
        DEPLOYMENT_START_TIME = ''
        DEPLOYMENT_END_TIME = ''
        INCIDENT_COUNT = '0'
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '📦 Récupération du code...'
                git branch: 'master', 
                    url: 'https://github.com/Yahya-maani/meditracker.git'
            }
        }
        
        stage('Setup Python') {
            steps {
                echo '🐍 Configuration de Python...'
                withPythonEnv('C:\\Users\\PC\\AppData\\Local\\Programs\\Python\\Python310\\python.exe') {
                    bat '''
                        echo "=== Installation des dépendances ==="
                        python --version
                        pip install --upgrade pip
                        pip install -r requirements.txt
                        pip install pytest pytest-cov flake8 prometheus_client
                        
                        echo "=== Vérification ==="
                        python -c "import flask; print('Flask OK')"
                        python -c "import pymongo; print('PyMongo OK')"
                        python -c "import prometheus_client; print('Prometheus OK')"
                    '''
                }
            }
        }
        
        stage('Run Tests') {
            steps {
                echo '🧪 Exécution des tests...'
                withPythonEnv('C:\\Users\\PC\\AppData\\Local\\Programs\\Python\\Python310\\python.exe') {
                    bat '''
                        echo "=== Lancement des tests ==="
                        if exist test_basic.py (
                            pytest test_basic.py -v --junitxml=test-results.xml
                        ) else (
                            echo "Test simple : Application chargée"
                            python -c "from app import app; print('Application OK')"
                        )
                    '''
                }
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                echo '🔍 Analyse SonarQube...'
                withSonarQubeEnv('sonar_integration') {
                    bat """
                        C:\\sonar-scanner-8.0.1.6346-windows-x64\\bin\\sonar-scanner.bat ^
                            -Dsonar.projectKey=${SONAR_PROJECT_KEY} ^
                            -Dsonar.sources=. ^
                            -Dsonar.python.version=3 ^
                            -Dsonar.sourceEncoding=UTF-8 ^
                            -Dsonar.exclusions=**/venv/**,**/__pycache__/**,**/.git/**,**/tests/**,**/migrations/**,**/site-packages/**,**/.pyenv*/**,**/Lib/**,**/Python310/**,**/.pytest_cache/**,**/*.pyc ^
                            -Dsonar.cpd.exclusions=**/tests/**,**/site-packages/**,**/.pyenv*/**,**/Lib/** ^
                            -Dsonar.python.coverage.reportPaths= ^
                            -Dsonar.python.xunit.reportPath=
                    """
                }
            }
        }
        
        stage('Quality Gate') {
            steps {
                echo '✅ Vérification Quality Gate...'
                timeout(time: 4, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        
        stage('Docker Build') {
    steps {
        echo '🐳 Construction de l\'image Docker...'
        script {
            // Use PowerShell instead of sh
            DEPLOYMENT_START_TIME = powershell(script: 'Get-Date -UFormat %s', returnStdout: true).trim()
            
            // Build Docker image
            bat """
                echo "=== Construction de l'image Docker ==="
                docker build -t ${DOCKER_IMAGE} .
                docker tag ${DOCKER_IMAGE} ${DOCKER_REGISTRY}/${DOCKER_IMAGE}
                
                echo "=== Scan de sécurité ==="
                docker scan ${DOCKER_IMAGE} || echo "Scan optionnel"
                
                echo "=== Image construite ==="
                docker images | findstr meditracker
            """
        }
    }
}
        
        stage('Docker Push') {
            steps {
                echo '📤 Push de l\'image vers le registre...'
                script {
                    bat """
                        echo "=== Push de l'image ==="
                        docker push ${DOCKER_REGISTRY}/${DOCKER_IMAGE}
                        
                        echo "=== Tag latest ==="
                        docker tag ${DOCKER_IMAGE} ${DOCKER_REGISTRY}/meditracker:latest
                        docker push ${DOCKER_REGISTRY}/meditracker:latest
                    """
                }
            }
        }
        
      stage('Deploy to Kubernetes') {
    steps {
        echo '🚀 Déploiement sur Kubernetes...'
        script {
            try {
                // Create namespace if not exists
                bat "kubectl create namespace ${K8S_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -"
                
                // Apply the service first (if not exists)
                bat "kubectl apply -f kubernetes/service.yaml -n ${K8S_NAMESPACE} || true"
                
                // Process the deployment.yaml with environment variables
                bat """
                    echo "=== Traitement du fichier de déploiement ==="
                    // Replace variables in deployment file
                    powershell -Command "& {
                        \$content = Get-Content kubernetes/deployment.yaml -Raw
                        \$content = \$content -replace '\\\$\\{DOCKER_REGISTRY\\}', '${DOCKER_REGISTRY}'
                        \$content = \$content -replace '\\\$\\{BUILD_NUMBER\\}', '${BUILD_NUMBER}'
                        Set-Content -Path kubernetes/deployment-processed.yaml -Value \$content
                    }"
                    
                    echo "=== Application du déploiement ==="
                    kubectl apply -f kubernetes/deployment-processed.yaml -n ${K8S_NAMESPACE}
                    
                    echo "=== Vérification du déploiement ==="
                    kubectl rollout status deployment/${DEPLOYMENT_NAME} -n ${K8S_NAMESPACE} --timeout=300s
                    
                    echo "=== Déploiement réussi avec image: ${DOCKER_REGISTRY}/meditracker:${BUILD_NUMBER} ==="
                    kubectl get pods -n ${K8S_NAMESPACE} -o wide
                """
                
                DEPLOYMENT_STATUS = 'success'
            } catch (err) {
                DEPLOYMENT_STATUS = 'failed'
                INCIDENT_COUNT = '1'
                error "Échec du déploiement: ${err}"
            finally {
    DEPLOYMENT_END_TIME = powershell(script: 'Get-Date -UFormat %s', returnStdout: true).trim()

        }
    }
}   
        stage('Health Check') {
            steps {
                echo '🏥 Vérification de la santé de l\'application...'
                script {
                    // Wait for application to be ready
                    sleep(10)
                    
                    // Test application endpoints
                    bat """
                        echo "=== Test des endpoints ==="
                        kubectl port-forward service/${DEPLOYMENT_NAME} 5000:5000 -n ${K8S_NAMESPACE} &
                        sleep 5
                        curl -f http://localhost:5000/ || exit 1
                        curl -f http://localhost:5000/metrics || echo "Metrics endpoint OK"
                        taskkill /F /IM kubectl.exe || true
                    """
                }
            }
        }
        
        stage('Setup Monitoring') {
            steps {
                echo '📊 Configuration du monitoring...'
                script {
                    // Install Prometheus if not present
                    bat """
                        echo "=== Installation de Prometheus ==="
                        kubectl apply -f kubernetes/monitoring/namespace.yaml || true
                        kubectl apply -f kubernetes/monitoring/prometheus-config.yaml || true
                        kubectl apply -f kubernetes/monitoring/prometheus-deployment.yaml || true
                        
                        echo "=== Installation de Grafana ==="
                        kubectl apply -f kubernetes/monitoring/grafana-deployment.yaml || true
                        
                        echo "=== Installation de ServiceMonitor ==="
                        kubectl apply -f kubernetes/monitoring/servicemonitor.yaml || true
                        
                        echo "=== Vérification des pods ==="
                        kubectl get pods -n monitoring
                    """
                }
            }
        }
        
        stage('Export Metrics') {
            steps {
                echo '📈 Export des métriques de déploiement...'
                script {
                    def mttr = 0
                    if (DEPLOYMENT_STATUS == 'failed') {
                        def start = DEPLOYMENT_START_TIME.toInteger()
                        def end = DEPLOYMENT_END_TIME.toInteger()
                        mttr = end - start
                    }
                    
                    // Create metrics file
                    writeFile file: 'deployment-metrics.txt', text: """
                    # Deployment Metrics
                    DEPLOYMENT_STATUS=${DEPLOYMENT_STATUS}
                    DEPLOYMENT_TIMESTAMP=${new Date().format('yyyy-MM-dd HH:mm:ss')}
                    BUILD_NUMBER=${BUILD_NUMBER}
                    MTTR_SECONDS=${mttr}
                    INCIDENT_COUNT=${INCIDENT_COUNT}
                    DEPLOYMENT_DURATION=${DEPLOYMENT_END_TIME.toInteger() - DEPLOYMENT_START_TIME.toInteger()}
                    """
                    
                    // Push metrics to Prometheus via pushgateway
                    bat """
                        echo "=== Push metrics to Prometheus Pushgateway ==="
                        curl -X POST --data-binary @deployment-metrics.txt \
                            http://localhost:9091/metrics/job/meditracker_deployment/instance/${BUILD_NUMBER}
                    """
                }
            }
        }
        stage('Create Grafana Dashboard') {
    steps {
        script {
            def dashboardJson = readFile('kubernetes/monitoring/grafana-dashboard.json')
            // Use bat instead of sh
            bat """
                echo "=== Creating Grafana Dashboard ==="
                curl -X POST -H "Content-Type: application/json" \
                    -d '{"dashboard":${dashboardJson},"overwrite":true}' \
                    http://admin:admin@grafana.monitoring:3000/api/dashboards/db || echo "Grafana not available"
            """
        }
    }
}
    }
    
    post {
        always {
            echo '🧹 Nettoyage terminé'
            script {
                // Cleanup old Docker images
                bat '''
                    docker image prune -f --filter "until=24h"
                '''
            }
            
            // Archive metrics
            archiveArtifacts artifacts: 'deployment-metrics.txt', fingerprint: true
            junit 'test-results.xml'
        }
        
        success {
            echo '✅ Pipeline réussi !'
            script {
                // Send success notification
                echo "Déploiement réussi - Build #${BUILD_NUMBER}"
            }
        }
        
        failure {
            echo '❌ Pipeline échoué'
            script {
                // Send failure notification
                echo "Échec du déploiement - Build #${BUILD_NUMBER}"
            }
        }
    }
}